#!/bin/bash
set -euo pipefail

# Prerequisite: curl is required to fetch vim-plug.
if ! command -v curl &> /dev/null; then
  echo "curl is required but not installed" >&2
  exit 1
fi

# Install vim-plug (Download plug.vim and put it in autoload directory)
if [ -f ~/.vim/autoload/plug.vim ]; then
  echo "Vim-Plug already in autoload"
else
  echo "Installing Vim-Plug"
  curl -fLo ~/.vim/autoload/plug.vim --create-dirs \
    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
fi

# Create symbolic links
echo "Creating symbolic links"
mkdir -p "$HOME/.vim"
ln -sf "$PWD/vimrc" "$HOME/.vimrc"
# -n so re-running links the dir itself instead of nesting inside an existing link.
ln -sfn "$PWD/colors" "$HOME/.vim/colors"
