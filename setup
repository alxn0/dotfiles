#!/bin/bash
set -euo pipefail

# Run each dotfiles/*/setup script.
# A single module failure is reported but does not abort the others.

# Always operate from the repository root, regardless of the caller's CWD.
cd "$(dirname "$0")"

for folder in dotfiles/*/; do
  [ -f "$folder/setup" ] || continue

  basename="$(basename "$folder")"
  echo "Setup $basename"

  # Subshell keeps the cd local; no need to cd back.
  if ! ( cd "$folder" && ./setup ); then
    echo "  ! $basename setup failed" >&2
  fi
done
